{
  "imposters": [
    {
      "port": 3001,
      "protocol": "http",
      "name": "Servico de Inventario e Pagamentos",
      "stubs": [
        {
          "predicates": [
            { "matches": { "path": "/inventory/.*", "method": "GET" } }
          ],
          "responses": [
            {
              "is": {
                "statusCode": 200,
                "headers": { "Content-Type": "application/json" },
                "body": "{\"sku\": \"SKU-001\", \"quantity\": 50, \"available\": true}"
              }
            }
          ]
        },
        {
          "predicates": [
            { "equals": { "path": "/payments", "method": "POST" } }
          ],
          "responses": [
            {
              "is": {
                "statusCode": 200,
                "headers": { "Content-Type": "application/json" },
                "body": "{\"transactionId\": \"TXN-12345\", \"status\": \"approved\", \"amount\": 29.99}"
              }
            }
          ]
        }
      ]
    }
  ]
}